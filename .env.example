# NextAuth — generate with: npx auth secret
AUTH_SECRET=
AUTH_URL=http://localhost:3033

# Google OAuth — from console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase PostgreSQL — from Supabase dashboard > Settings > Database
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Resend — from resend.com/api-keys
RESEND_API_KEY=re_...
