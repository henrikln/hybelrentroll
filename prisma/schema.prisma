generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  member
}

enum UnitType {
  enebolig
  leilighet
  hybel
  naering
  annet
}

enum ContractStatus {
  aktiv
  ledig
  oppsagt
}

enum ContractType {
  tidsbestemt
  tidsubestemt
}

enum SecurityType {
  depositum
  forsikring
  garanti
  ingen
}

enum ImportSource {
  email
  upload
  api
}

enum ImportStatus {
  pending
  processing
  completed
  failed
}

/// Multi-tenancy root. One account per logged-in user/org (e.g. Henrik's account).
/// An account can own multiple companies (Utleier).
model Account {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  companies       Company[]
  rentRollImports RentRollImport[]
  apiKeys         ApiKey[]
  allowedSenders  AllowedSender[]

  @@map("accounts")
}

/// A registered Norwegian company (AS) that acts as landlord (Utleier).
/// Each rent roll file belongs to one company, identified by org number.
model Company {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId String   @map("account_id") @db.Uuid
  name      String
  orgNumber String   @map("org_number")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account            Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  properties         Property[]
  units              Unit[]
  leaseholders       Leaseholder[]
  contracts          Contract[]
  securityDeposits   SecurityDeposit[]
  rentAdjustments    RentAdjustment[]
  rentRollImports    RentRollImport[]
  rentRollSnapshots  RentRollSnapshot[]
  unitEvents         UnitEvent[]

  @@unique([accountId, orgNumber])
  @@map("companies")
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId String   @map("account_id") @db.Uuid
  email     String   @unique
  name      String?
  role      UserRole @default(member)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  apiKeys ApiKey[]
  imports RentRollImport[]

  @@map("users")
}

model Property {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  streetName   String   @map("street_name")
  streetNumber String   @map("street_number")
  postalCode   String   @map("postal_code")
  postalPlace  String   @map("postal_place")
  municipality String?
  gnr          Int      @default(0)
  bnr          Int      @default(0)
  snr          Int?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  units   Unit[]

  @@unique([companyId, streetName, streetNumber, postalCode, gnr, bnr])
  @@map("properties")
}

model Unit {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  propertyId   String   @map("property_id") @db.Uuid
  unitNumber   String   @default("") @map("unit_number")
  customNumber String   @default("") @map("custom_number")
  unitType     UnitType @default(annet) @map("unit_type")
  numRooms     Int?     @map("num_rooms")
  areaSqm      Decimal? @map("area_sqm") @db.Decimal(8, 2)
  numBedrooms  Int?     @map("num_bedrooms")
  floor        Int?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  property  Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  contracts Contract[]

  @@unique([propertyId, unitNumber, customNumber])
  @@map("units")
}

/// A person renting a unit (leietaker). Named "Leaseholder" to avoid confusion
/// with "tenant" in the multi-tenancy sense.
model Leaseholder {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  name         String
  email        String   @default("")
  phone        String?
  invoiceEmail String?  @map("invoice_email")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contracts Contract[]

  @@unique([companyId, name, email])
  @@map("leaseholders")
}

model Contract {
  id                       String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId                String         @map("company_id") @db.Uuid
  unitId                   String         @map("unit_id") @db.Uuid
  leaseholderId            String?        @map("leaseholder_id") @db.Uuid
  externalContractId       String?        @map("external_contract_id")
  status                   ContractStatus @default(ledig)
  contractType             ContractType?  @map("contract_type")
  startDate                DateTime?      @map("start_date") @db.Date
  endDate                  DateTime?      @map("end_date") @db.Date
  terminationDate          DateTime?      @map("termination_date") @db.Date
  noticePeriodMonths       Int?           @map("notice_period_months")
  earliestNoticeDate       DateTime?      @map("earliest_notice_date") @db.Date
  monthlyRent              Decimal?       @map("monthly_rent") @db.Decimal(10, 2)
  fixedReduction           Decimal?       @map("fixed_reduction") @db.Decimal(10, 2)
  lastRentAdjustmentDate   DateTime?      @map("last_rent_adjustment_date") @db.Date
  nextRentAdjustmentDate   DateTime?      @map("next_rent_adjustment_date") @db.Date
  rentBeforeLastAdjustment Decimal?       @map("rent_before_last_adjustment") @db.Decimal(10, 2)
  cpiBase                  Decimal?       @map("cpi_base") @db.Decimal(8, 2)
  akontoElectricity        Decimal?       @map("akonto_electricity") @db.Decimal(10, 2)
  akontoWaterSewage        Decimal?       @map("akonto_water_sewage") @db.Decimal(10, 2)
  createdAt                DateTime       @default(now()) @map("created_at")
  updatedAt                DateTime       @updatedAt @map("updated_at")

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  unit            Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  leaseholder     Leaseholder?     @relation(fields: [leaseholderId], references: [id], onDelete: SetNull)
  securityDeposit SecurityDeposit?
  rentAdjustments RentAdjustment[]

  @@unique([companyId, externalContractId])
  @@map("contracts")
}

model SecurityDeposit {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String       @map("company_id") @db.Uuid
  contractId   String       @unique @map("contract_id") @db.Uuid
  securityType SecurityType @map("security_type")
  amount       Decimal?     @db.Decimal(10, 2)
  createdAt    DateTime     @default(now()) @map("created_at")

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("security_deposits")
}

model RentAdjustment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String   @map("company_id") @db.Uuid
  contractId     String   @map("contract_id") @db.Uuid
  adjustmentDate DateTime @map("adjustment_date") @db.Date
  rentBefore     Decimal? @map("rent_before") @db.Decimal(10, 2)
  rentAfter      Decimal? @map("rent_after") @db.Decimal(10, 2)
  cpiIndexBase   Decimal? @map("cpi_index_base") @db.Decimal(8, 2)
  cpiIndexNew    Decimal? @map("cpi_index_new") @db.Decimal(8, 2)
  adjustmentPct  Decimal? @map("adjustment_pct") @db.Decimal(5, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("rent_adjustments")
}

model RentRollImport {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId    String       @map("account_id") @db.Uuid
  companyId    String?      @map("company_id") @db.Uuid
  filename     String
  source       ImportSource
  senderEmail  String?      @map("sender_email")
  status       ImportStatus @default(pending)
  rowsTotal    Int?         @map("rows_total")
  rowsImported Int?         @map("rows_imported")
  rowsFailed   Int?         @map("rows_failed")
  errorLog     Json?        @map("error_log")
  fileUrl      String?      @map("file_url")
  importedById String?      @map("imported_by_user_id") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at")
  completedAt  DateTime?    @map("completed_at")

  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  company    Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  importedBy User?    @relation(fields: [importedById], references: [id], onDelete: SetNull)
  snapshots  RentRollSnapshot[]
  unitEvents UnitEvent[]

  @@map("rent_roll_imports")
}

model ApiKey {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId   String    @map("account_id") @db.Uuid
  name        String
  keyPrefix   String    @map("key_prefix")
  keyHash     String    @map("key_hash")
  scopes      String[]
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdById String    @map("created_by_user_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")

  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

/// Maps sender email addresses to accounts for email ingestion.
/// All emails to the system inbox are resolved via this table.
model AllowedSender {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId String   @map("account_id") @db.Uuid
  email     String
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([email])
  @@map("allowed_senders")
}

/// Denormalized snapshot of every unit at import time.
/// One row per unit per import — immutable history for diffing.
model RentRollSnapshot {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  importId           String    @map("import_id") @db.Uuid
  companyId          String    @map("company_id") @db.Uuid
  reportDate         DateTime  @map("report_date") @db.Date
  unitKey            String    @map("unit_key")
  // Property
  streetName         String    @map("street_name")
  streetNumber       String    @map("street_number")
  postalCode         String    @map("postal_code")
  postalPlace        String    @map("postal_place")
  gnr                Int?
  bnr                Int?
  unitNumber         String?   @map("unit_number")
  customNumber       String?   @map("custom_number")
  unitType           String    @map("unit_type")
  numRooms           Int?      @map("num_rooms")
  areaSqm            Decimal?  @map("area_sqm") @db.Decimal(8, 2)
  numBedrooms        Int?      @map("num_bedrooms")
  floor              Int?
  // Contract
  externalContractId String?   @map("external_contract_id")
  status             String
  contractType       String?   @map("contract_type")
  startDate          DateTime? @map("start_date") @db.Date
  endDate            DateTime? @map("end_date") @db.Date
  noticePeriodMonths Int?      @map("notice_period_months")
  earliestNoticeDate DateTime? @map("earliest_notice_date") @db.Date
  monthlyRent        Decimal?  @map("monthly_rent") @db.Decimal(10, 2)
  fixedReduction     Decimal?  @map("fixed_reduction") @db.Decimal(10, 2)
  lastRentAdjDate    DateTime? @map("last_rent_adj_date") @db.Date
  nextRentAdjDate    DateTime? @map("next_rent_adj_date") @db.Date
  rentBeforeLastAdj  Decimal?  @map("rent_before_last_adj") @db.Decimal(10, 2)
  cpiBase            Decimal?  @map("cpi_base") @db.Decimal(8, 2)
  akontoElectricity  Decimal?  @map("akonto_electricity") @db.Decimal(10, 2)
  akontoWaterSewage  Decimal?  @map("akonto_water_sewage") @db.Decimal(10, 2)
  // Leaseholder
  leaseholderName    String?   @map("leaseholder_name")
  leaseholderEmail   String?   @map("leaseholder_email")
  leaseholderPhone   String?   @map("leaseholder_phone")
  // Security
  securityType       String?   @map("security_type")
  securityAmount     Decimal?  @map("security_amount") @db.Decimal(10, 2)
  createdAt          DateTime  @default(now()) @map("created_at")

  import  RentRollImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, unitKey, reportDate])
  @@map("rent_roll_snapshots")
}

/// Events auto-generated by diffing consecutive rent roll snapshots.
/// Provides a timeline of all changes per unit over time.
model UnitEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  importId    String   @map("import_id") @db.Uuid
  unitKey     String   @map("unit_key")
  eventDate   DateTime @map("event_date") @db.Date
  eventType   String   @map("event_type")
  description String
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  createdAt   DateTime @default(now()) @map("created_at")

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  import  RentRollImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([companyId, eventDate])
  @@index([companyId, unitKey])
  @@map("unit_events")
}
