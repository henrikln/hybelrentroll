generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  member
}

enum UnitType {
  enebolig
  leilighet
  hybel
  naering
  annet
}

enum ContractStatus {
  aktiv
  ledig
  oppsagt
}

enum ContractType {
  tidsbestemt
  tidsubestemt
}

enum SecurityType {
  depositum
  forsikring
  garanti
  ingen
}

enum ImportSource {
  email
  upload
  api
}

enum ImportStatus {
  pending
  processing
  completed
  failed
}

model Organization {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkOrgId  String   @unique @map("clerk_org_id")
  name        String
  orgNumber   String?  @map("org_number")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users            User[]
  properties       Property[]
  units            Unit[]
  tenants          Tenant[]
  contracts        Contract[]
  securityDeposits SecurityDeposit[]
  rentAdjustments  RentAdjustment[]
  rentRollImports  RentRollImport[]
  apiKeys          ApiKey[]

  @@map("organizations")
}

model User {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkUserId    String   @unique @map("clerk_user_id")
  organizationId String   @map("organization_id") @db.Uuid
  email          String
  name           String?
  role           UserRole @default(member)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apiKeys      ApiKey[]
  imports      RentRollImport[]

  @@map("users")
}

model Property {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  streetName     String   @map("street_name")
  streetNumber   String   @map("street_number")
  postalCode     String   @map("postal_code")
  postalPlace    String   @map("postal_place")
  municipality   String?
  gnr            Int?
  bnr            Int?
  snr            Int?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  units        Unit[]

  @@unique([organizationId, streetName, streetNumber, postalCode, gnr, bnr])
  @@map("properties")
}

model Unit {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  propertyId     String   @map("property_id") @db.Uuid
  unitNumber     String?  @map("unit_number")
  customNumber   String?  @map("custom_number")
  unitType       UnitType @default(annet) @map("unit_type")
  numRooms       Int?     @map("num_rooms")
  areaSqm        Decimal? @map("area_sqm") @db.Decimal(8, 2)
  numBedrooms    Int?     @map("num_bedrooms")
  floor          Int?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  contracts    Contract[]

  @@unique([propertyId, unitNumber, customNumber])
  @@map("units")
}

model Tenant {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  email          String?
  phone          String?
  invoiceEmail   String?  @map("invoice_email")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contracts    Contract[]

  @@unique([organizationId, name, email])
  @@map("tenants")
}

model Contract {
  id                       String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId           String         @map("organization_id") @db.Uuid
  unitId                   String         @map("unit_id") @db.Uuid
  tenantId                 String?        @map("tenant_id") @db.Uuid
  externalContractId       String?        @map("external_contract_id")
  status                   ContractStatus @default(ledig)
  contractType             ContractType?  @map("contract_type")
  startDate                DateTime?      @map("start_date") @db.Date
  endDate                  DateTime?      @map("end_date") @db.Date
  terminationDate          DateTime?      @map("termination_date") @db.Date
  noticePeriodMonths       Int?           @map("notice_period_months")
  earliestNoticeDate       DateTime?      @map("earliest_notice_date") @db.Date
  monthlyRent              Decimal?       @map("monthly_rent") @db.Decimal(10, 2)
  fixedReduction           Decimal?       @map("fixed_reduction") @db.Decimal(10, 2)
  lastRentAdjustmentDate   DateTime?      @map("last_rent_adjustment_date") @db.Date
  nextRentAdjustmentDate   DateTime?      @map("next_rent_adjustment_date") @db.Date
  rentBeforeLastAdjustment Decimal?       @map("rent_before_last_adjustment") @db.Decimal(10, 2)
  cpiBase                  Decimal?       @map("cpi_base") @db.Decimal(8, 2)
  akontoElectricity        Decimal?       @map("akonto_electricity") @db.Decimal(10, 2)
  akontoWaterSewage        Decimal?       @map("akonto_water_sewage") @db.Decimal(10, 2)
  createdAt                DateTime       @default(now()) @map("created_at")
  updatedAt                DateTime       @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  unit            Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  securityDeposit SecurityDeposit?
  rentAdjustments RentAdjustment[]

  @@unique([organizationId, externalContractId])
  @@map("contracts")
}

model SecurityDeposit {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  contractId     String       @unique @map("contract_id") @db.Uuid
  securityType   SecurityType @map("security_type")
  amount         Decimal?     @db.Decimal(10, 2)
  createdAt      DateTime     @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contract     Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("security_deposits")
}

model RentAdjustment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  contractId     String   @map("contract_id") @db.Uuid
  adjustmentDate DateTime @map("adjustment_date") @db.Date
  rentBefore     Decimal? @map("rent_before") @db.Decimal(10, 2)
  rentAfter      Decimal? @map("rent_after") @db.Decimal(10, 2)
  cpiIndexBase   Decimal? @map("cpi_index_base") @db.Decimal(8, 2)
  cpiIndexNew    Decimal? @map("cpi_index_new") @db.Decimal(8, 2)
  adjustmentPct  Decimal? @map("adjustment_pct") @db.Decimal(5, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contract     Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("rent_adjustments")
}

model RentRollImport {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  filename       String
  source         ImportSource
  senderEmail    String?      @map("sender_email")
  status         ImportStatus @default(pending)
  rowsTotal      Int?         @map("rows_total")
  rowsImported   Int?         @map("rows_imported")
  rowsFailed     Int?         @map("rows_failed")
  errorLog       Json?        @map("error_log")
  fileUrl        String?      @map("file_url")
  importedById   String?      @map("imported_by_user_id") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at")
  completedAt    DateTime?    @map("completed_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  importedBy   User?        @relation(fields: [importedById], references: [id], onDelete: SetNull)

  @@map("rent_roll_imports")
}

model ApiKey {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  keyPrefix      String    @map("key_prefix")
  keyHash        String    @map("key_hash")
  scopes         String[]
  lastUsedAt     DateTime? @map("last_used_at")
  expiresAt      DateTime? @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  createdById    String    @map("created_by_user_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@map("api_keys")
}
